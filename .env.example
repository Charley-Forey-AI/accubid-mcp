OPENID_CONFIGURATION_URL=https://id.trimble.com/.well-known/openid-configuration
CLIENT_ID=your_trimble_client_id
CLIENT_SECRET=your_trimble_client_secret
# Space- or comma-separated scopes for RFC 8693 token exchange (must match your Trimble app registration).
ACCUBID_SCOPE="openid accubid_agentic_ai"

ACCUBID_API_BASE_URL=https://cloud.api.trimble.com/anywhere
ACCUBID_API_VERSION_DATABASE=v1
ACCUBID_API_VERSION_ESTIMATE=v2
ACCUBID_API_VERSION_PROJECT=v2
ACCUBID_API_VERSION_CHANGEORDER=v1
ACCUBID_API_VERSION_CLOSEOUT=v1
ACCUBID_API_VERSION=v1

ACCUBID_REQUEST_TIMEOUT_SECONDS=30
ACCUBID_CLIENT_RETRY_COUNT=1
ACCUBID_CLIENT_RETRY_BASE_SECONDS=0.3
ACCUBID_CLIENT_RETRY_MAX_SECONDS=2.0
ACCUBID_CLIENT_RETRYABLE_STATUS_CODES=429,500,502,503,504
ACCUBID_CIRCUIT_BREAKER_FAILURES=5
ACCUBID_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30
ACCUBID_RATE_LIMIT_RPS=0
ACCUBID_LIST_DEFAULT_PAGE_SIZE=100
ACCUBID_LIST_MAX_PAGE_SIZE=500
ACCUBID_CACHE_ENABLED=false
ACCUBID_CACHE_TTL_SECONDS=60
ACCUBID_CACHE_STATE_FILE=
ACCUBID_CIRCUIT_STATE_FILE=
ACCUBID_COMPOSED_TOOL_CONCURRENCY=4

HEALTHCHECK_VERIFY_DEPENDENCIES=false
STARTUP_VALIDATE_DEPENDENCIES=false
STARTUP_VALIDATE_ACCUBID=false
ENABLE_METRICS=false
METRICS_ROUTE=/metrics
REQUEST_ID_HEADER=x-request-id
ACCUBID_TOOL_NAMESPACE=
ACCUBID_RESPONSE_SNAKE_CASE=false
# Danger: logs full OAuth bearer on each Accubid request. Use briefly to copy into Postman.
# ACCUBID_DEBUG_LOG_OUTBOUND_TOKEN=true

ENV=development
# MCP_CORS_ORIGINS=https://studio.ai.trimble.com

ACCUBID_TOOLS_DISABLE_DATABASE=false
ACCUBID_TOOLS_DISABLE_PROJECT=false
ACCUBID_TOOLS_DISABLE_ESTIMATE=false
ACCUBID_TOOLS_DISABLE_CLOSEOUT=false
ACCUBID_TOOLS_DISABLE_CHANGEORDER=false

LOG_LEVEL=INFO

# Streamable HTTP (required for Agent Studio — Authorization: Bearer actor token per request)
MCP_HOST=0.0.0.0
MCP_PORT=8012
MCP_HTTP_PATH=mcp/accubid
