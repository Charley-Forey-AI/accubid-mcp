OPENID_CONFIGURATION_URL=https://id.trimble.com/.well-known/openid-configuration
CLIENT_ID=your_trimble_client_id
CLIENT_SECRET=your_trimble_client_secret
# Space-separated Trimble scopes for each Accubid Anywhere API area (commas are normalized to spaces).
# Example: anywhere-database anywhere-project anywhere-estimate anywhere-closeout anywhere-changeorder
ACCUBID_SCOPE="openid accubid_agentic_ai"
# Optional RFC 8707 resource URI for On-Behalf-Of token exchange only — set only if Trimble Identity docs/support require it (e.g. audience-bound tokens).
# ACCUBID_TOKEN_EXCHANGE_RESOURCE=

# API auth: server (CLIENT_ID/SECRET + ACCUBID_OAUTH_GRANT), delegated (Agent Studio actor JWT + Trimble token exchange per request), hybrid (exchange when actor present, else server OAuth).
ACCUBID_AUTH_MODE=server
# Hybrid only: when true, do not run token exchange even if Agent Studio sends an actor JWT — use server OAuth for Accubid (same as Postman auth-code path if ACCUBID_OAUTH_GRANT=authorization_code). Actor JWT still validated for error diagnostics.
# ACCUBID_HYBRID_ACCUBID_USE_SERVER_OAUTH=false
# Delegated / hybrid with actor — CLIENT_ID, CLIENT_SECRET, and ACCUBID_SCOPE are required: the MCP exchanges the inbound actor token at id.trimble.com/oauth/token (RFC 8693) so Accubid calls use your subscribed app. In Trimble Developer Console, enable token exchange (On-Behalf-Of) for CLIENT_ID.
# Delegated / hybrid — validate actor JWT with Trimble JWKS (JWKS URL defaults from OPENID_CONFIGURATION_URL if unset):
# ACCUBID_DELEGATED_VERIFY=true
# ACCUBID_DELEGATED_ISSUER=https://id.trimble.com
# ACCUBID_DELEGATED_JWKS_URL=
# ACCUBID_DELEGATED_AUDIENCE=
# Required scopes must appear in the JWT `scope` claim (Agent Studio UI may list openid but it is often omitted there).
# ACCUBID_DELEGATED_REQUIRED_SCOPES=accubid_agentic_ai openid

# Trimble OAuth grant: client_credentials (default, app-only) or authorization_code (user login + token file).
# ACCUBID_OAUTH_GRANT=client_credentials
# For authorization_code: register OAUTH_REDIRECT_URI on your Trimble app (must match exactly).
# accubid-mcp-oauth-login listens on loopback only — use e.g. http://127.0.0.1:8765/oauth/callback (not an external flows.ai/n8n URL unless you paste tokens manually).
ACCUBID_OAUTH_GRANT=authorization_code
OAUTH_REDIRECT_URI=http://127.0.0.1:8765/oauth/callback
OAUTH_TOKEN_PATH=~/.accubid-mcp/token.json

ACCUBID_API_BASE_URL=https://cloud.api.trimble.com/anywhere
# Per-module API path versions (…/anywhere/{area}/{version}/…). Override only if Trimble changes a module.
ACCUBID_API_VERSION_DATABASE=v1
ACCUBID_API_VERSION_ESTIMATE=v2
ACCUBID_API_VERSION_PROJECT=v2
ACCUBID_API_VERSION_CHANGEORDER=v1
ACCUBID_API_VERSION_CLOSEOUT=v1
# Fallback for unknown area keys only (built-in tools use the vars above).
ACCUBID_API_VERSION=v1
ACCUBID_REQUEST_TIMEOUT_SECONDS=30
ACCUBID_CLIENT_RETRY_COUNT=1
ACCUBID_CLIENT_RETRY_BASE_SECONDS=0.3
ACCUBID_CLIENT_RETRY_MAX_SECONDS=2.0
ACCUBID_CLIENT_RETRYABLE_STATUS_CODES=429,500,502,503,504
ACCUBID_CIRCUIT_BREAKER_FAILURES=5
ACCUBID_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30
ACCUBID_RATE_LIMIT_RPS=0
ACCUBID_LIST_DEFAULT_PAGE_SIZE=100
ACCUBID_LIST_MAX_PAGE_SIZE=500
ACCUBID_CACHE_ENABLED=false
ACCUBID_CACHE_TTL_SECONDS=60
ACCUBID_CACHE_STATE_FILE=
ACCUBID_CIRCUIT_STATE_FILE=
ACCUBID_COMPOSED_TOOL_CONCURRENCY=4
ACCUBID_TOKEN_REFRESH_BUFFER_SECONDS=90
ACCUBID_TOKEN_TTL_SECONDS=3300
HEALTHCHECK_VERIFY_DEPENDENCIES=false
# If true, validates tokens before uvicorn starts. With ACCUBID_OAUTH_GRANT=authorization_code, missing
# tokens no longer abort startup (server binds; add OAUTH_TOKEN_PATH or run accubid-mcp-oauth-login).
STARTUP_VALIDATE_DEPENDENCIES=false
STARTUP_VALIDATE_ACCUBID=false
ENABLE_METRICS=false
METRICS_ROUTE=/metrics
REQUEST_ID_HEADER=x-request-id
ACCUBID_TOOL_NAMESPACE=
ACCUBID_RESPONSE_SNAKE_CASE=false
# Danger: logs full OAuth bearer on every Accubid request (journald). Use briefly to copy into Postman, then set false.
# Unquoted: ACCUBID_DEBUG_LOG_OUTBOUND_TOKEN=true  (also accepts 1 / yes / on). On startup you should see a WARN that debug is enabled.
ENV=development
# APP_VERSION=0.1.0
# MCP_CORS_ORIGINS=https://example.com,https://example2.com

ACCUBID_TOOLS_DISABLE_DATABASE=false
ACCUBID_TOOLS_DISABLE_PROJECT=false
ACCUBID_TOOLS_DISABLE_ESTIMATE=false
ACCUBID_TOOLS_DISABLE_CLOSEOUT=false
ACCUBID_TOOLS_DISABLE_CHANGEORDER=false

LOG_LEVEL=INFO
# LOG_FORMAT=json

# HTTP mode
MCP_HOST=0.0.0.0
MCP_PORT=8012
MCP_HTTP_PATH=mcp/accubid

ACCUBID_DELEGATED_REQUIRED_SCOPES="openid accubid_agentic_ai"
