            "nullable": true
          },
          "vendors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Vendor"
            },
            "description": "List of vendors related to the project.",
            "nullable": true
          },
          "folderID": {
            "type": "string",
            "description": "FolderID",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Project info."
      },
