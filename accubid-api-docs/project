            "type": "string",
            "description": "Date the project was created.",
            "format": "date-time"
          },
          "createdBy": {
            "minLength": 1,
            "type": "string",
            "description": "Name of person who created the project."
          },
          "managingBranchName": {
            "minLength": 1,
            "type": "string",
