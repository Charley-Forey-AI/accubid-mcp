  "components": {
    "schemas": {
      "CreateFolderInfo": {
        "required": [
          "databaseToken",
          "description"
        ],
        "type": "object",
        "properties": {
          "databaseToken": {
            "minLength": 1,
            "type": "string"
          },
          "parentFolderID": {
            "type": "string",
            "description": "ParentFolderID for the new folder. FolderIDs can be retrieved from the GetFolders API call.  To create a folder at the root level, use null as the ParentFolderID.",
            "nullable": true
          },
          "description": {
            "minLength": 1,
            "type": "string",
            "description": "Description (name) for the new folder.  Max length is 128 characters."
          }
        },
        "additionalProperties": false
      },
      "CreateFolderResult": {
        "type": "object",
        "properties": {
          "folderID": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateProjectInfo": {
        "required": [
          "databaseToken",
          "folderID",
          "name",
          "number"
        ],
        "type": "object",
        "properties": {
          "databaseToken": {
            "minLength": 1,
            "type": "string"
          },
          "folderID": {
            "minLength": 1,
            "type": "string",
            "description": "FolderID for the new project. FolderIDs can be retrieved from the GetFolders API call."
          },
          "name": {
            "minLength": 1,
            "type": "string",
            "description": "Name for the new project.  Max length is 64 characters."
          },
          "number": {
            "minLength": 1,
            "type": "string",
            "description": "Number for the new project.  Max length is 32 characters."
          }
        },
        "additionalProperties": false
      },
      "CreateProjectResult": {
        "type": "object",
        "properties": {
          "projectID": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "FolderListInfo": {
        "required": [
          "folderID",
          "name",
          "parentFolderID"
        ],
        "type": "object",
        "properties": {
          "folderID": {
            "minLength": 1,
            "type": "string",
            "description": "FolderID"
          },
          "parentFolderID": {
            "minLength": 1,
            "type": "string",
            "description": "ParentFolderID"
          },
          "name": {
            "minLength": 1,
