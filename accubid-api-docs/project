          "vendorName"
        ],
        "type": "object",
        "properties": {
          "vendorName": {
            "minLength": 1,
            "type": "string",
            "description": "Name of the vendor."
          },
          "vendorCode": {
            "minLength": 1,
            "type": "string",
            "description": "Code for the vendor"
          },
          "supplierExchange": {
            "type": "integer",
            "description": "Supplier Exchange id for the vendor.",
            "format": "int32"
          }
        },
        "additionalProperties": false,
        "description": "Vendor information"
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "<p>Enter into the value field the word 'Bearer', a space, and the TID access token.<br>Example: Bearer 409b57d4c516de618a95dfa9e6ca92dd<p>Logging out does not log you out of TID",
